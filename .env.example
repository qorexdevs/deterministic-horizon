# Environment Configuration for Deterministic Horizon Experiments
# ================================================================
# Copy this file to .env and fill in your API keys
#
# SECURITY: Never commit .env to version control!

# =============================================================================
# Required: API Keys
# =============================================================================

# OpenAI API Key 
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# =============================================================================
# Optional: HuggingFace (for local models)
# =============================================================================

# HuggingFace Token (for gated models like Llama)
HF_TOKEN=hf_your-huggingface-token-here

# =============================================================================
# Optional: Experiment Tracking
# =============================================================================

# Weights & Biases (for experiment tracking)
WANDB_API_KEY=your-wandb-key-here
WANDB_PROJECT=deterministic-horizon
WANDB_ENTITY=your-username

# =============================================================================
# Optional: Performance Settings
# =============================================================================

# Number of parallel API requests (default: 5)
MAX_CONCURRENT_REQUESTS=5

# Request timeout in seconds (default: 120)
API_TIMEOUT=120

# Retry attempts for failed requests (default: 3)
MAX_RETRIES=3

# =============================================================================
# Optional: Local Model Settings
# =============================================================================

# CUDA device(s) for local models
CUDA_VISIBLE_DEVICES=0,1,2,3

# HuggingFace cache directory
HF_HOME=/path/to/huggingface/cache

# vLLM settings (if using vLLM backend)
VLLM_TENSOR_PARALLEL_SIZE=4

# =============================================================================
# Optional: Output Settings
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Results directory
RESULTS_DIR=results

# Cache directory
CACHE_DIR=.cache
