# --- Byte-compiled / cache ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Distribution / packaging ---
.Python
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
.python-version

# --- Test / type / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# --- Notebooks ---
.ipynb_checkpoints/

# --- Editors / IDEs ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini

# --- Secrets and local config ---
.env
.env.local
.env.*.local
*.pem

# --- Experiment artefacts (regenerable) ---
# We deliberately keep results/sample/ and the analysis/ artefacts that
# accompany the paper. Local runs go under */local/ or */runs/ and are ignored.
checkpoints/
runs/
wandb/
mlruns/
results/local/
results/runs/
analysis/local/
analysis/runs/

# --- LaTeX build artefacts (keep PDF + sources) ---
paper/*.aux
paper/*.log
paper/*.out
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fls
paper/*.fdb_latexmk

# --- Hugging Face / large model files ---
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
# LaTeX build aux only; the .tex and .bib sources are tracked.
paper/algorithm.sty
paper/algorithmic.sty
paper/fancyhdr.sty
